Options -MultiViews

RewriteEngine On

# Serve pretty page URLs before Apache can treat matching asset folders as directories.
RewriteRule ^gallery/?$ gallery.html [L]

# Redirect /index.html to /
RewriteCond %{THE_REQUEST} /index\.html [NC]
RewriteRule ^ / [L,R=301]

# Redirect /page.html to /page
RewriteCond %{THE_REQUEST} /([^.]+)\.html [NC]
RewriteRule ^ /%1 [L,R=301]

# Map /page to /page.html internally
# We check for the .html file first, even if a directory exists with the same name
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [L]
